# Required secrets.
HF_TOKEN=hf_xxx
WANDB_API_KEY=wandb_xxx
KIMINA_BASE_URL=https://your-kimina-server.example.com
KIMINA_API_KEY=

# Core contract.
MODEL_NAME_OR_PATH=Pythagoras-LM/Pythagoras-Prover-4B
DATASET_NAME=AI-MO/NuminaMath-LEAN
DATASET_SPLIT=train
OUTPUT_ROOT=/workspace/outputs/treepo-runs
# Compatibility alias for generic TRL RunPod audits; method-specific OUTPUT_DIR is derived by default.
OUTPUT_DIR=/workspace/outputs/treepo-runs/grpo
HUB_MODEL_PREFIX=your-hf-user/pythagoras-prover-4b-numina-lean
PUSH_TO_HUB=false
HUB_PRIVATE_REPO=true
HF_TOKEN_REQUIRED=true

# Pick one method, or set RUN_ALL_EXPERIMENTS=true.
METHOD=grpo
RUN_ALL_EXPERIMENTS=false
EXPERIMENT=

# Smoke defaults. Increase deliberately for production.
TRAIN_SIZE=64
# Compatibility alias for generic TRL RunPod audits. TRAIN_SIZE is the source of truth.
MAX_TRAIN_SAMPLES=64
VAL_SIZE=16
TEST_SIZE=16
MAX_STEPS=10
LOGGING_STEPS=1
SAVE_STEPS=10
EVAL_STEPS=10
REPORT_TO=none
WANDB_PROJECT=lean-treepo

# Production TreePO/GRPO defaults from the plan.
NUM_GENERATIONS=16
MAX_PROMPT_LENGTH=1024
MAX_COMPLETION_LENGTH=7168
TREE_SEGMENT_LENGTH=512
TREE_MAX_DEPTH=14
TREE_FIXED_STEP_WIDTH=2
TREE_MORE_INIT_MIN=2
TREE_MORE_INIT_MAX=8
TREE_REPETITION_NGRAM_CHARS=32
TREE_REPETITION_COUNT=8
TEMPERATURE=1.0
TOP_P=1.0
TOP_K=0
BETA=0.0
LOSS_TYPE=dapo
SCALE_REWARDS=group

# LoRA and optimizer knobs kept consistent across ablations.
BF16=true
USE_4BIT=true
USE_PEFT=true
LORA_R=64
LORA_ALPHA=128
LORA_DROPOUT=0.05
LORA_TARGET_MODULES=q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj
PER_DEVICE_TRAIN_BATCH_SIZE=1
PER_DEVICE_EVAL_BATCH_SIZE=1
GRADIENT_ACCUMULATION_STEPS=16
LEARNING_RATE=1e-6
WARMUP_RATIO=0.03
SEED=42
GRADIENT_CHECKPOINTING=true

# Evaluation and plotting.
EVAL_N_SAMPLES=16
EVAL_MAX_SAMPLES=128
PLOTS_RUNS_DIR=/workspace/outputs/treepo-runs

# RunPod restart guard.
USE_ACCELERATE=false
ACCELERATE_NUM_PROCESSES=1
IDLE_AFTER_SUCCESS=true
RUN_ONCE_MARKER=/workspace/.lean_treepo_success
FORCE_RERUN=false
